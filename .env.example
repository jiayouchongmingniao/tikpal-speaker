# tikpal-speaker target-device environment
#
# Copy the relevant values into the target device service environment.
# Do not commit real API keys, OAuth client secrets, provider tokens, or release credentials.

# System API
TIKPAL_API_KEY=change-me-admin-key
TIKPAL_FLOW_API_HOST=0.0.0.0
TIKPAL_FLOW_API_PORT=8787
TIKPAL_ALLOWED_ORIGINS=https://tikpal.ai,https://www.tikpal.ai,http://localhost:4173,http://localhost:3000

# Persistence
TIKPAL_DISABLE_PERSISTENCE=0

# Calendar connector
TIKPAL_CALENDAR_CONNECTOR_MODE=real
TIKPAL_CALENDAR_API_BASE=https://www.googleapis.com/calendar/v3
TIKPAL_CALENDAR_TOKEN_URL=https://oauth2.googleapis.com/token
TIKPAL_CALENDAR_CLIENT_ID=
TIKPAL_CALENDAR_CLIENT_SECRET=
TIKPAL_CALENDAR_ID=primary

# Todoist connector
TIKPAL_TODOIST_CONNECTOR_MODE=real
TIKPAL_TODOIST_API_BASE=https://api.todoist.com/rest/v2
TIKPAL_TODOIST_TOKEN_URL=
TIKPAL_TODOIST_CLIENT_ID=
TIKPAL_TODOIST_CLIENT_SECRET=

# Player bridge
TIKPAL_PLAYER_BACKEND=mpc
TIKPAL_MPD_HOST=127.0.0.1
TIKPAL_MPD_PORT=6600
TIKPAL_PLAYER_API_BASE=http://localhost:9001/player
TIKPAL_PLAYER_TIMEOUT_MS=5000

# OTA
TIKPAL_OTA_RELEASE_ROOT=/opt/tikpal/app/releases
TIKPAL_OTA_CURRENT_PATH=/opt/tikpal/app/current
TIKPAL_OTA_PREVIOUS_PATH=/opt/tikpal/app/previous
TIKPAL_OTA_HEALTH_FILE=health.json
TIKPAL_OTA_RESTART_COMMAND=sudo systemctl restart tikpal-api tikpal-web

# Validation helpers
TIKPAL_VALIDATION_API_BASE=http://localhost:8787/api/v1/system
