[Unit]
Description=Tikpal Speaker Web UI Service
After=network.target
Wants=network.target

[Service]
Type=simple
User=@SERVICE_USER@
Group=@SERVICE_GROUP@
WorkingDirectory=@APP_DIR@
Environment=NODE_ENV=production
ExecStart=/usr/bin/env npm run preview -- --host 0.0.0.0 --port 4173
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
